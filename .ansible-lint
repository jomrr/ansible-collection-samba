---
# Production profile = strictest built-in profile.
# Deliberately NO skip_list, NO warn_list downgrades, NO disabled rules.
# If a rule fires, fix the code — do not relax this file.
profile: production

exclude_paths:
  # Exclude only the generated changelog artifacts (their YAML style is the
  # antsibull-changelog serializer's, not ours to edit); the authored
  # changelogs/fragments/ are linted.
  - changelogs/changelog.yaml
  - changelogs/.plugin-cache.yaml
  - .github/
