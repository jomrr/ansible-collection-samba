---
# Production profile = strictest built-in profile.
# Deliberately NO skip_list, NO warn_list downgrades, NO disabled rules.
# If a rule fires, fix the code — do not relax this file.
profile: production

exclude_paths:
  # GitHub Actions workflows are not Ansible content. All of changelogs/ now
  # passes lint (changelog.yaml via changelog_nice_yaml in changelogs/config.yaml).
  - .github/
